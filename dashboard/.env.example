# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/minerva?sslmode=require

# Auth.js
AUTH_SECRET=your-auth-secret-here  # Generate with: npx auth secret
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Alibaba Cloud OSS (S3-compatible)
S3_ENDPOINT=https://oss-us-east-1.aliyuncs.com
S3_REGION=us-east-1
S3_BUCKET=minerva-documents
S3_ACCESS_KEY_ID=your-alibaba-access-key-id
S3_SECRET_ACCESS_KEY=your-alibaba-secret-access-key
# Set to 'true' for S3-compatible providers (like AliCloud OSS, MinIO) that require bucket name in URL path.
# Set to 'false' for AWS S3 to use virtual-hosted style (preferable for AWS).
S3_FORCE_PATH_STYLE=true
